{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "title": "Collective",
  "required": [
    "id",
    "type",
    "name"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "type": {
      "const": "collective"
    },
    "name": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "members": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "links": {
      "type": "object"
    }
  }
}

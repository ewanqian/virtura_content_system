{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "title": "Person",
  "required": [
    "id",
    "type",
    "name"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "type": {
      "const": "person"
    },
    "name": {
      "type": "string"
    },
    "roles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "summary": {
      "type": "string"
    },
    "links": {
      "type": "object"
    },
    "featuredImage": {
      "type": "string"
    }
  }
}

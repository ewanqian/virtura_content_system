{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "title": "Venue",
  "required": [
    "id",
    "type",
    "title"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "type": {
      "const": "venue"
    },
    "title": {
      "type": "string"
    },
    "location": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "screen": {
      "type": "object"
    },
    "relatedWorks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}

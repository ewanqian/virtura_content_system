{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "title": "Relation",
  "required": [
    "id",
    "type",
    "from",
    "to",
    "relationType"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "type": {
      "const": "relation"
    },
    "from": {
      "type": "string"
    },
    "to": {
      "type": "string"
    },
    "relationType": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    }
  }
}

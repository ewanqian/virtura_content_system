{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "title": "Writing",
  "required": [
    "id",
    "type",
    "title"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "type": {
      "const": "writing"
    },
    "title": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "relatedWork": {
      "type": "string"
    },
    "relatedNode": {
      "type": "string"
    },
    "path": {
      "type": "string"
    }
  }
}
